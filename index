<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estrela Cadente - Magical Experience 🌸</title>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Quicksand:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-pink: #ffafbd;
            --secondary-pink: #ffc3a0;
            --soft-purple: #cbb4d4;
            --mint: #a8e6cf;
            --vanilla: #fdffcd;
            --text-dark: #5d4037;
            --white: #ffffff;
            --card-bg: rgba(255, 255, 255, 0.85);
        }

        /* Reset e Base */
        * { margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth; }
        
        body {
            font-family: 'Quicksand', sans-serif;
            background: linear-gradient(45deg, var(--primary-pink), var(--soft-purple), var(--vanilla));
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            color: var(--text-dark);
            overflow-x: hidden;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Barra de Navegação Fofa */
        nav {
            background: var(--card-bg);
            backdrop-filter: blur(8px);
            padding: 15px;
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: center;
            gap: 25px;
            border-bottom: 4px dashed var(--primary-pink);
        }

        nav a {
            text-decoration: none;
            color: var(--text-dark);
            font-weight: 700;
            font-size: 1.1rem;
            transition: 0.3s;
        }

        nav a:hover { color: var(--primary-pink); transform: scale(1.2) rotate(-5deg); }

        /* Header Gigante */
        header {
            height: 80vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            position: relative;
        }

        .floating-title {
            animation: float 4s infinite ease-in-out;
            background: var(--card-bg);
            padding: 40px;
            border-radius: 50px;
            border: 5px solid var(--white);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

        h1 { font-family: 'Fredoka One', cursive; font-size: 4.5rem; color: #ff6b81; text-shadow: 4px 4px 0px white; }

        /* Seções do Site */
        .section { padding: 80px 20px; max-width: 1100px; margin: 0 auto; }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .card {
            background: var(--card-bg);
            border-radius: 40px;
            padding: 40px;
            border: 3px solid var(--white);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            transition: 0.4s;
            position: relative;
            overflow: hidden;
        }

        .card:hover { transform: translateY(-15px); box-shadow: 0 20px 40px rgba(255, 107, 129, 0.2); }

        /* Galeria Interativa */
        .gallery {
            display: flex;
            gap: 15px;
            overflow-x: auto;
            padding: 20px 0;
        }

        .gallery-item {
            min-width: 200px;
            height: 200px;
            background: var(--mint);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            transition: 0.5s;
            cursor: pointer;
        }

        .gallery-item:hover { flex: 2; transform: rotate(5deg); background: var(--secondary-pink); }

        /* Mini Game */
        #game-area {
            height: 300px;
            background: var(--white);
            border-radius: 40px;
            position: relative;
            margin-top: 20px;
            border: 3px dashed var(--soft-purple);
            overflow: hidden;
            cursor: crosshair;
        }

        .heart-target {
            position: absolute;
            font-size: 2rem;
            cursor: pointer;
            transition: 0.2s;
            user-select: none;
        }

        /* Botões e Inputs */
        .btn-magical {
            background: linear-gradient(to right, #ff9a9e, #fad0c4);
            border: none;
            padding: 15px 40px;
            border-radius: 30px;
            color: white;
            font-family: 'Fredoka One', cursive;
            font-size: 1.2rem;
            cursor: pointer;
            box-shadow: 0 8px 0 #e88a8e;
            margin: 10px;
        }

        .btn-magical:active { box-shadow: 0 0 0; transform: translateY(8px); }

        /* Animações */
        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0); }
            50% { transform: translateY(-20px) rotate(2deg); }
        }

        /* Rastro de Estrela */
        .star {
            position: absolute;
            width: 15px;
            height: 15px;
            background: gold;
            clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
            pointer-events: none;
            animation: starFade 0.8s forwards;
        }

        @keyframes starFade {
            to { opacity: 0; transform: scale(2) translateY(50px) rotate(180deg); }
        }

        footer { text-align: center; padding: 60px; font-size: 1.2rem; background: var(--white); }
    </style>
</head>
<body>

    <nav>
        <a href="#inicio">Início</a>
        <a href="#sobre">Fofura Acadêmica</a>
        <a href="#mini-game">Mini-Game</a>
        <a href="#galeria">Galeria</a>
    </nav>

    <header id="inicio">
        <div class="floating-title">
            <h1>Yasmin's Magical Space</h1>
            <p>Seja bem-vinda ao meu cantinho cheio de glitter e ciência! ✨</p>
            <br>
            <button class="btn-magical" onclick="tocarMusica()">Clique para Magia! ✨</button>
        </div>
    </header>

    <div class="section" id="sobre">
        <div class="grid-container">
            <div class="card">
                <h2>☁️ Nuvem de Pensamentos</h2>
                <p>Aqui colocamos ideias que flutuam! Sabia que o cérebro de uma pessoa feliz brilha mais em exames de imagem? (Ok, essa é uma licença poética científica!)</p>
            </div>
            <div class="card" style="background: var(--mint);">
                <h2>🧸 O Fator Ursinho</h2>
                <p>Estudos mostram que olhar para imagens de animais filhotes aumenta a concentração e o foco em tarefas detalhadas. Use isso na sua monitoria!</p>
            </div>
        </div>
    </div>

    <div class="section" id="mini-game">
        <div class="card">
            <h2>💖 Catch the Heart!</h2>
            <p>Tente clicar no coração que foge! Pontos: <span id="score">0</span></p>
            <div id="game-area">
                <div id="target" class="heart-target">💗</div>
            </div>
        </div>
    </div>

    <div class="section" id="galeria">
        <h2>🌈 Galeria de Emojis Gigantes</h2>
        <div class="gallery">
            <div class="gallery-item">🌸</div>
            <div class="gallery-item">🍭</div>
            <div class="gallery-item">🎀</div>
            <div class="gallery-item">🦄</div>
            <div class="gallery-item">🎨</div>
            <div class="gallery-item">🍦</div>
        </div>
    </div>

    <footer>
        <p>Criado com 💖 por Yasmin Vitórya</p>
        <p style="font-size: 0.8rem; margin-top: 10px;">© 2026 - Onde a ciência encontra a fofura</p>
    </footer>

    <script>
        // Sistema de Pontuação do Game
        let score = 0;
        const target = document.getElementById('target');
        const scoreDisplay = document.getElementById('score');
        const gameArea = document.getElementById('game-area');

        function moveTarget() {
            const maxX = gameArea.clientWidth - 50;
            const maxY = gameArea.clientHeight - 50;
            const randomX = Math.floor(Math.random() * maxX);
            const randomY = Math.floor(Math.random() * maxY);
            
            target.style.left = randomX + 'px';
            target.style.top = randomY + 'px';
        }

        target.addEventListener('mouseover', () => {
            moveTarget();
        });

        target.addEventListener('click', () => {
            score++;
            scoreDisplay.innerText = score;
            target.innerText = '✨';
            setTimeout(() => { target.innerText = '💗'; }, 200);
            moveTarget();
        });

        // Efeito de Rastro de Estrelas
        document.addEventListener('mousemove', (e) => {
            if (Math.random() > 0.8) { // Não criar tantas estrelas para não pesar
                const star = document.createElement('div');
                star.className = 'star';
                star.style.left = e.pageX + 'px';
                star.style.top = e.pageY + 'px';
                document.body.appendChild(star);
                setTimeout(() => star.remove(), 800);
            }
        });

        // Função do Botão de Magia
        function tocarMusica() {
            alert("✨ Magia Ativada! ✨\nQue seu dia seja tão brilhante quanto esse código!");
            document.body.style.filter = "saturate(1.5)";
            setTimeout(() => { document.body.style.filter = "none"; }, 2000);
        }

        moveTarget(); // Inicializar posição do coração
    </script>
</body>
</html>
